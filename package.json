{
  "name": "telemetryflow-core",
  "version": "1.4.0",
  "description": "TelemetryFlow Core - IAM, AI Assistant & Audit Platform",
  "private": true,
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "bootstrap": "bash scripts/bootstrap.sh",
    "dev": "turbo run dev",
    "dev:backend": "turbo run dev --filter=@telemetryflow/backend",
    "dev:frontend": "turbo run dev --filter=@telemetryflow/viz",
    "build": "turbo run build",
    "build:backend": "turbo run build --filter=@telemetryflow/backend",
    "build:frontend": "turbo run build --filter=@telemetryflow/viz",
    "start": "node dist/main",
    "start:debug": "turbo run start:debug",
    "lint": "eslint \"{backend,test}/**/*.ts\"",
    "lint:fix": "eslint \"{backend,test}/**/*.ts\" --fix",
    "clean": "rm -rf dist node_modules backend/dist backend/node_modules frontend/dist frontend/node_modules",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:clean": "bash scripts/docker-volumes-clean.sh",
    "db:cleanup": "bash scripts/db-cleanup.sh",
    "db:migrate": "TS_NODE_PROJECT=backend/tsconfig.json ts-node backend/src/database/postgres/migration-runner.ts && TS_NODE_PROJECT=backend/tsconfig.json ts-node backend/src/database/clickhouse/migration-runner.ts",
    "db:migrate:postgres": "TS_NODE_PROJECT=backend/tsconfig.json ts-node backend/src/database/postgres/migration-runner.ts",
    "db:migrate:postgres:iam": "TS_NODE_PROJECT=backend/tsconfig.json ts-node backend/src/database/postgres/migration-runner.ts --modules=iam",
    "db:migrate:postgres:auth": "TS_NODE_PROJECT=backend/tsconfig.json ts-node backend/src/database/postgres/migration-runner.ts --modules=auth",
    "db:migrate:clickhouse": "TS_NODE_PROJECT=backend/tsconfig.json ts-node backend/src/database/clickhouse/migration-runner.ts",
    "db:migrate:clickhouse:audit": "TS_NODE_PROJECT=backend/tsconfig.json ts-node backend/src/database/clickhouse/migration-runner.ts --modules=audit",
    "db:seed": "TS_NODE_PROJECT=backend/tsconfig.json ts-node backend/src/database/postgres/seed-runner.ts && TS_NODE_PROJECT=backend/tsconfig.json ts-node backend/src/database/clickhouse/seed-runner.ts",
    "db:seed:postgres": "TS_NODE_PROJECT=backend/tsconfig.json ts-node backend/src/database/postgres/seed-runner.ts",
    "db:seed:postgres:iam": "TS_NODE_PROJECT=backend/tsconfig.json ts-node backend/src/database/postgres/seed-runner.ts --modules=iam",
    "db:seed:postgres:auth": "TS_NODE_PROJECT=backend/tsconfig.json ts-node backend/src/database/postgres/seed-runner.ts --modules=auth",
    "db:seed:clickhouse": "TS_NODE_PROJECT=backend/tsconfig.json ts-node backend/src/database/clickhouse/seed-runner.ts",
    "db:migrate:seed": "pnpm db:migrate && pnpm db:seed",
    "db:fresh": "pnpm db:cleanup && pnpm db:migrate && pnpm db:seed",
    "generate:secrets": "node scripts/generate-secrets.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@nestjs/cli": "^11.0.14",
    "@types/node": "^25.0.6",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.50.1",
    "eslint": "^9.39.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "turbo": "^2.9.8",
    "typescript": "5.9.3"
  }
}
